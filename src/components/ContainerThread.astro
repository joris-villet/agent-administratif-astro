---
import Thread from './Thread.svelte';
import UserLogged from "@/components/UserLogged.astro"

interface Props {
  threadId?: string;
}

const { threadId } = Astro.props;
---

<aside class="w-[400px] shrink-0 bg-custom flex flex-col rounded-2xl overflow-hidden text-white">

  <!-- Header -->
  <div class="px-5 pt-6 pb-5 flex items-center gap-3">
    <div class="w-10 h-10 rounded-2xl bg-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/30">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-bold leading-tight text-white">Agent-Administratif</p>
      <p class="text-xs text-slate-400 leading-tight mt-0.5">Votre assistant administratif</p>
    </div>
    <button class="shrink-0 text-slate-500 hover:text-slate-300 transition-colors p-1.5 rounded-lg hover:bg-white/10">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </button>
  </div>

  <!-- Dynamic thread list + new conversation button -->
  <Thread client:load threadId={threadId ?? ''} />

  <!-- Footer -->
  <div class="flex px-4 pb-5 pt-4 border-t border-white/10 space-y-1">
    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-400 hover:text-white hover:bg-white/10 transition-all">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Paramètres
    </button>
  </div>
  <div class="flex px-4 pb-5 pt-4 border-t border-white/10 space-y-1">
    <UserLogged />
  </div>

</aside>

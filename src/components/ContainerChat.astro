---
import ContainerMessages from './ContainerMessages.svelte';
import InputPrompt from './InputPrompt.svelte';
---

<section class="flex-1 flex flex-col bg-surface rounded-2xl overflow-hidden shadow-sm border border-border min-w-0">

  <!-- Welcome header -->
  <div class="px-7 py-5 flex items-start justify-between gap-6 border-b border-border">
    <div class="flex items-center gap-4">
      <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center shrink-0 border border-border">
        <svg class="w-8 h-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .3 2.7-1.17 2.7H3.968c-1.47 0-2.17-1.7-1.17-2.7L4 15.3"/>
          <circle cx="12" cy="8" r="2" stroke-width="1.5"/>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-800">Bonjour Julie,</h1>
        <p class="text-base text-slate-600">Je suis votre agent-administratif virtuel.</p>
        <p class="text-sm text-muted mt-0.5">Je suis là pour vous accompagner dans vos démarches.</p>
      </div>
    </div>
    <!-- Security badge -->
    <div class="shrink-0 flex items-start gap-2.5 px-4 py-3 rounded-xl border border-border bg-slate-50 max-w-[220px]">
      <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-slate-700">Vos données sont sécurisées</p>
        <p class="text-xs text-muted mt-0.5">Vos informations et documents sont confidentiels et protégés.</p>
      </div>
    </div>
  </div>

  <!-- Messages area -->
  <div class="flex-1 min-h-0 flex flex-col overflow-hidden px-6">
    <ContainerMessages client:only="svelte" />
  </div>

  <!-- Input area -->
  <div>
    <InputPrompt client:only="svelte" />
    <p class="text-xs text-muted text-center pb-3 flex items-center justify-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-accent-light shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.347.347a3.5 3.5 0 01-4.95 0l-.347-.347z"/>
      </svg>
      Soyez précis dans votre demande pour une réponse plus adaptée.
    </p>
  </div>

</section>


---
import Logout from "@/components/Logout.svelte";
const session = Astro.locals;
---

<div
	class="w-full flex items-center justify-between gap-3 px-3 py-2.5 rounded-xl hover:bg-white/10 transition-all"
>
	<div class="flex items-center gap-3">
		<div
			class="w-9 h-9 rounded-full bg-slate-600/80 flex items-center justify-center shrink-0 overflow-hidden"
		>
			<img
				class="w-full h-full object-cover"
				src="/img/photo-user.webp"
				alt="Julie Martin"
				loading="lazy"
			/>
		</div>
		<div class="flex-1 min-w-0 text-left">
			<p class="text-xs text-slate-400 truncate">{session.user?.email}</p>
		</div>
	</div>
	<div>
		<Logout client:only="svelte" />
	</div>
</div>

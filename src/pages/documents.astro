---
import IconListThreads from "@/components/Icons/IconListThreads.svelte";
import UserLogged from "@/components/UserLogged.astro";
import Layout from "@/layouts/Layout.astro";
import TabsFilters from "@/components/PageDocuments/TabsFilters.svelte";
---

<Layout>
  <div class="h-screen p-3 flex gap-3">
    <aside
      class="w-100 shrink-0 bg-custom flex flex-col rounded-2xl overflow-hidden text-white"
    >
      <!-- Header -->
      <div class="px-5 pt-6 pb-5 flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-2xl bg-accent flex items-center justify-center shrink-0 shadow-lg shadow-accent/30"
        >
          <svg
            class="w-5 h-5 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold leading-tight text-white">
            Agent-Administratif
          </p>
          <p class="text-xs text-slate-400 leading-tight mt-0.5">
            Votre assistant administratif
          </p>
        </div>
      </div>

      <div class="p-4">
        <div class="flex gap-4 items-center px-5 pb-6">
          <IconListThreads />
          <a href="/chat">Conversations</a>
        </div>
        <hr class="text-neutral-400" />
      </div>

      <div class="flex px-4 pb-5 pt-4 border-t border-white/10 space-y-1"></div>
      <div class="flex px-4 pb-5 pt-4 border-t border-white/10 space-y-1">
        <UserLogged />
      </div>
    </aside>

    <section
      class="flex-1 flex flex-col bg-surface rounded-2xl overflow-hidden shadow-sm border border-border min-w-0"
    >
      <TabsFilters client:load />
    </section>
    <aside
      class="w-125 shrink-0 bg-surface rounded-2xl overflow-hidden shadow-sm border border-border flex flex-col"
    >
      visual document
    </aside>
  </div>
</Layout>
